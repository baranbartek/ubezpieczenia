# Netlify cache headers — optymalizacja LCP i powracających użytkowników

# HTML — zawsze świeże (revalidate przy każdej wizycie)
/*.html
  Cache-Control: public, max-age=0, must-revalidate

/
  Cache-Control: public, max-age=0, must-revalidate

# Fonty — cache na rok (niezmienne pliki)
/fonts/*.woff2
  Cache-Control: public, max-age=31536000, immutable

/fontawesome/webfonts/*.woff2
  Cache-Control: public, max-age=31536000, immutable

/fontawesome/webfonts/*.ttf
  Cache-Control: public, max-age=31536000, immutable

# CSS — cache na rok
/dist/*.css
  Cache-Control: public, max-age=31536000, immutable

/fontawesome/css/*.css
  Cache-Control: public, max-age=31536000, immutable

# Obrazy — cache na rok
/*.jpg
  Cache-Control: public, max-age=31536000, immutable

/*.png
  Cache-Control: public, max-age=31536000, immutable

/*.svg
  Cache-Control: public, max-age=31536000, immutable

/logos/*.svg
  Cache-Control: public, max-age=31536000, immutable
